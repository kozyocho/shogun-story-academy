// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User.id = Supabase Auth UUID (no default — set at sign-in callback)
model User {
  id            String    @id
  email         String    @unique
  name          String?
  image         String?
  busho         Int       @default(0)
  rank          Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastReadAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription Subscription?
  progress     StoryProgress[]
  scrolls      Scroll[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  // status: FREE | ACTIVE | PAST_DUE | CANCELED | TRIALING | LIFETIME
  status               String  @default("FREE")
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Story {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  era         String
  figure      String?
  imageUrl    String?
  isPremium   Boolean  @default(false)
  order       Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags          StoryTag[]
  vocabulary    VocabularyNote[]
  questions     ComprehensionQuestion[]
  progress      StoryProgress[]
  timelineEvent TimelineEvent?
  decisions     StoryDecision[]
}

model StoryTag {
  id      String @id @default(cuid())
  storyId String
  name    String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model VocabularyNote {
  id          String @id @default(cuid())
  storyId     String
  term        String
  reading     String?
  definition  String
  culturalNote String?

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model ComprehensionQuestion {
  id      String   @id @default(cuid())
  storyId String
  question String
  options String   // JSON array of options
  answer  Int      // index of correct option

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id          String @id @default(cuid())
  storyId     String @unique
  year        Int
  title       String
  description String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Scroll {
  id         String   @id @default(cuid())
  userId     String
  type       String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model StoryDecision {
  id             String @id @default(cuid())
  storyId        String
  afterParagraph Int
  question       String
  optionA        String
  optionB        String
  optionC        String
  correctOption  Int
  historicalNote String
  wrongNote      String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryProgress {
  id          String   @id @default(cuid())
  userId      String
  storyId     String
  completed   Boolean  @default(false)
  completedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
}
